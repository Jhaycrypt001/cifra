# Copy to .env.local and fill after `npm run deploy:sepolia` in ../contracts

# --- Chain ---
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_CHAIN_ID_HEX=0xaa36a7
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.org

# --- Deployed contract addresses (from contracts/deployments/addresses.sepolia.json) ---
NEXT_PUBLIC_CUSDT_ADDRESS=0x...
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_POOL_ADDRESS=0x...

# --- Web3Auth (web2+web3 sign-in) ---
# Free clientId from https://dashboard.web3auth.io (create a "Web3Auth Modal" project,
# add http://localhost:3000 and your Vercel URL to allowed origins).
# If left blank, the app falls back to MetaMask-only sign-in.
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=
